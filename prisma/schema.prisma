generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Todo {
  id        String   @id @default(cuid())
  title     String
  assignee  String
  dueDate   DateTime?
  content   String
  status    Status   @default(TODO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}
